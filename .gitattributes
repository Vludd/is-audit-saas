# Auto detect text files and perform LF normalization
* text=auto

*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text

*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

*.pdf binary
*.sqlite3 binary